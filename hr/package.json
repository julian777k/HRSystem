{
  "name": "msa-hr",
  "version": "0.2.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:seed": "npx prisma db seed",
    "db:push:sqlite": "npx prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:generate:sqlite": "npx prisma generate --schema=prisma/schema.sqlite.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:db": "docker compose up -d db",
    "electron:compile": "npx tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && DB_PROVIDER=sqlite NEXT_PUBLIC_DB_PROVIDER=sqlite npx electron .",
    "electron:dist": "npx tsx scripts/build-electron.ts",
    "electron:dist:mac": "npx tsx scripts/build-electron.ts darwin",
    "electron:dist:win": "npx tsx scripts/build-electron.ts win32",
    "cf:build": "bash scripts/build-cloudflare.sh",
    "cf:dev": "npx wrangler dev",
    "cf:deploy": "npx wrangler deploy"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "pg-cloudflare": "^1.3.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prisma": "^7.4.0",
    "puppeteer": "^24.37.3",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.71.0"
  }
}
