generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// SaaS Multi-tenant Models
// ============================================================

model Tenant {
  id            String   @id @default(cuid())
  name          String
  subdomain     String   @unique
  customDomain  String?
  plan          String   @default("standard")
  maxEmployees  Int      @default(50)
  ownerEmail    String
  bizNumber     String?
  status          String    @default("active")
  trialExpiresAt  DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([subdomain])
  @@index([status])
  @@map("tenants")
}

model TenantSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, key])
  @@map("tenant_settings")
}

model SuperAdmin {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  name               String
  role               String    @default("SUPER_ADMIN")
  mustChangePassword Boolean   @default(false)
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  @@map("super_admins")
}

model TenantUsageLog {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime
  apiCalls  Int      @default(0)
  dbReads   Int      @default(0)
  dbWrites  Int      @default(0)
  createdAt DateTime @default(now())
  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("tenant_usage_logs")
}

// ============================================================
// Core Models (with tenantId for multi-tenant isolation)
// ============================================================

model Department {
  id             String       @id @default(cuid())
  tenantId       String       @default("")
  name           String
  code           String
  parentId       String?
  parent         Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children       Department[] @relation("DeptTree")
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  workStartTime  String?                        // 부서 기본 출근 시간 (HH:mm)
  workEndTime    String?                        // 부서 기본 퇴근 시간
  lunchStartTime String?                        // 점심 시작
  lunchEndTime   String?                        // 점심 종료
  employees      Employee[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model Position {
  id         String     @id @default(cuid())
  tenantId   String     @default("")
  name       String
  level      Int
  isActive   Boolean    @default(true)
  employees  Employee[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  @@unique([tenantId, name])
  @@unique([tenantId, level])
  @@index([tenantId])
  @@map("positions")
}

model Employee {
  id              String    @id @default(cuid())
  tenantId        String    @default("")
  employeeNumber  String
  name            String
  email           String
  passwordHash    String
  phone           String?
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id])
  positionId      String
  position        Position   @relation(fields: [positionId], references: [id])
  hireDate        DateTime
  resignDate      DateTime?
  status          EmployeeStatus @default(ACTIVE)
  role            SystemRole     @default(BASIC)
  profileImage    String?
  customPermissions  String?
  workType        String?                        // "FIXED" | "FLEXIBLE" | null(회사기본)
  workStartTime   String?                        // 개인 출근 시간 (HH:mm)
  workEndTime     String?                        // 개인 퇴근 시간
  lunchStartTime  String?                        // 점심 시작
  lunchEndTime    String?                        // 점심 종료
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  leaveGrants        LeaveGrant[]
  approvalSteps      ApprovalStep[]
  approvals          Approval[]
  overtimeRequests   OvertimeRequest[]
  sessions           Session[]
  notifications      Notification[]
  timeWallets        TimeWallet[]
  timeDeductions     TimeDeduction[]
  compTimeAccruals   CompTimeAccrual[]
  welfareRequests    WelfareRequest[]
  attendances        Attendance[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@unique([tenantId, email])
  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([departmentId])
  @@index([positionId])
  @@index([status])
  @@map("employees")
}

enum EmployeeStatus {
  ACTIVE
  PENDING
  ON_LEAVE
  RESIGNED
}

enum SystemRole {
  SYSTEM_ADMIN
  COMPANY_ADMIN
  DEPT_ADMIN
  BASIC
}

model ViewPermission {
  id          String     @id @default(cuid())
  tenantId    String     @default("")
  employeeId  String
  scope       ViewScope
  createdAt   DateTime   @default(now())
  @@unique([tenantId, employeeId, scope])
  @@index([tenantId])
  @@map("view_permissions")
}

enum ViewScope {
  COMPANY
  DEPARTMENT
}

model Session {
  id           String   @id @default(cuid())
  tenantId     String   @default("")
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  @@index([tenantId])
  @@index([employeeId])
  @@index([expiresAt])
  @@map("sessions")
}

model LeaveType {
  id             String   @id @default(cuid())
  tenantId       String   @default("")
  name           String
  code           String
  isPaid         Boolean  @default(true)
  isAnnualDeduct Boolean  @default(false)
  maxDays        Float?
  requiresDoc    Boolean  @default(false)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  leaveRequests  LeaveRequest[]
  leavePolicies  LeavePolicy[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("leave_types")
}

model LeavePolicy {
  id              String    @id @default(cuid())
  tenantId        String    @default("")
  leaveTypeId     String
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id])
  name            String
  description     String?
  yearFrom        Int
  yearTo          Int?
  grantDays       Float
  grantType       GrantType
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([tenantId])
  @@index([leaveTypeId])
  @@map("leave_policies")
}

enum GrantType {
  MONTHLY
  YEARLY
  ONCE
}

model LeaveGrant {
  id            String    @id @default(cuid())
  tenantId      String    @default("")
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeCode String
  grantDays     Float
  usedDays      Float     @default(0)
  remainDays    Float
  grantReason   String
  periodStart   DateTime
  periodEnd     DateTime
  isExpired     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([tenantId])
  @@index([employeeId])
  @@index([periodEnd])
  @@index([employeeId, leaveTypeCode, periodStart])
  @@map("leave_grants")
}

model LeaveBalance {
  id            String   @id @default(cuid())
  tenantId      String   @default("")
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year          Int
  leaveTypeCode String
  totalGranted  Float    @default(0)
  totalUsed     Float    @default(0)
  totalRemain   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([tenantId, employeeId, year, leaveTypeCode])
  @@index([tenantId])
  @@index([year, leaveTypeCode])
  @@map("leave_balances")
}

model LeaveRequest {
  id              String        @id @default(cuid())
  tenantId        String        @default("")
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id])
  leaveTypeId     String
  leaveType       LeaveType     @relation(fields: [leaveTypeId], references: [id])
  startDate       DateTime
  endDate         DateTime
  useUnit         LeaveUnit
  requestDays     Float
  requestHours    Float
  dailyHours      Float         @default(8)
  reason          String?
  status          LeaveStatus   @default(PENDING)
  appliedAt       DateTime      @default(now())
  cancelReason    String?
  cancelledAt     DateTime?
  approvalLineId  String?
  currentStep     Int           @default(1)
  approvals       Approval[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([leaveTypeId])
  @@map("leave_requests")
}

enum LeaveUnit {
  FULL_DAY
  AM_HALF
  PM_HALF
  HOURS
}

enum LeaveStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalLine {
  id          String          @id @default(cuid())
  tenantId    String          @default("")
  name        String
  type        ApprovalLineType
  isDefault   Boolean         @default(false)
  isActive    Boolean         @default(true)
  steps       ApprovalStep[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([tenantId])
  @@map("approval_lines")
}

enum ApprovalLineType {
  LEAVE
  OVERTIME
  GENERAL
}

model ApprovalStep {
  id              String       @id @default(cuid())
  tenantId        String       @default("")
  approvalLineId  String
  approvalLine    ApprovalLine @relation(fields: [approvalLineId], references: [id], onDelete: Cascade)
  stepOrder       Int
  approverId      String?
  approver        Employee?    @relation(fields: [approverId], references: [id])
  approverRole    ApproverRole
  actionType      ApprovalActionType
  positionLevel   Int?
  @@unique([tenantId, approvalLineId, stepOrder])
  @@index([tenantId])
  @@map("approval_steps")
}

enum ApproverRole {
  FIXED
  DEPT_HEAD
  UPPER_POSITION
  SKIP_TO_HEAD
  POSITION
}

enum ApprovalActionType {
  APPROVE
  AGREE
  NOTIFY
}

model Approval {
  id              String          @id @default(cuid())
  tenantId        String          @default("")
  leaveRequestId  String?
  leaveRequest    LeaveRequest?   @relation(fields: [leaveRequestId], references: [id])
  overtimeId      String?
  overtime        OvertimeRequest? @relation(fields: [overtimeId], references: [id])
  stepOrder       Int
  approverId      String
  approver        Employee        @relation(fields: [approverId], references: [id])
  action          ApprovalAction
  comment         String?
  processedAt     DateTime?
  createdAt       DateTime        @default(now())
  @@index([tenantId])
  @@index([leaveRequestId])
  @@index([overtimeId])
  @@index([approverId])
  @@index([approverId, action])
  @@map("approvals")
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

model OvertimeRequest {
  id            String          @id @default(cuid())
  tenantId      String          @default("")
  employeeId    String
  employee      Employee        @relation(fields: [employeeId], references: [id])
  date          DateTime
  overtimeType  OvertimeType
  startTime     String
  endTime       String
  hours         Float
  reason        String
  status        LeaveStatus     @default(PENDING)
  approvals     Approval[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  @@index([tenantId])
  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@map("overtime_requests")
}

enum OvertimeType {
  WEEKDAY_OVERTIME
  NIGHT
  WEEKEND
  HOLIDAY
}

model OvertimePolicy {
  id              String   @id @default(cuid())
  tenantId        String   @default("")
  maxWeeklyHours  Float    @default(12)
  maxMonthlyHours Float    @default(52)
  nightStartTime  String   @default("22:00")
  nightEndTime    String   @default("06:00")
  weekdayRate     Float    @default(1.5)
  weekendRate     Float    @default(1.5)
  nightRate       Float    @default(2.0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([tenantId])
  @@map("overtime_policies")
}

model ExternalIntegration {
  id           String   @id @default(cuid())
  tenantId     String   @default("")
  employeeId   String
  service      String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([tenantId, employeeId, service])
  @@index([tenantId])
  @@map("external_integrations")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String   @default("")
  employeeId  String?
  action      String
  target      String
  targetId    String
  before      String?
  after       String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  @@index([tenantId])
  @@index([employeeId])
  @@index([target, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// IMPORTANT: SystemConfig for setup wizard settings
model SystemConfig {
  id        String   @id @default(cuid())
  tenantId  String   @default("")
  key       String
  value     String
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("system_configs")
}

model Holiday {
  id          String   @id @default(cuid())
  tenantId    String   @default("")
  name        String
  date        DateTime
  isRecurring Boolean  @default(false)
  type        String   @default("PUBLIC")        // "PUBLIC" | "COMPANY" | "DEPARTMENT"
  targetId    String?                             // type=DEPARTMENT일 때 departmentId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([tenantId])
  @@index([date])
  @@index([type])
  @@map("holidays")
}

model PasswordReset {
  id        String    @id @default(cuid())
  tenantId  String    @default("")
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([tenantId])
  @@index([email])
  @@map("password_resets")
}

model Notification {
  id         String   @id @default(cuid())
  tenantId   String   @default("")
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  isRead     Boolean  @default(false)
  link       String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([employeeId, isRead])
  @@map("notifications")
}

// ============================================================
// 시간 지갑 (Time Wallet) 시스템 - 보상시간/연차 통합 관리
// ============================================================

enum TimeWalletType {
  COMP_TIME  // 보상시간 (연장근무 대체휴무)
  ANNUAL     // 연차시간
}

model TimeWallet {
  id          String         @id @default(cuid())
  tenantId    String         @default("")
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        TimeWalletType
  year        Int
  totalEarned Float          @default(0)
  totalUsed   Float          @default(0)
  totalRemain Float          @default(0)
  updatedAt   DateTime       @updatedAt

  @@unique([tenantId, employeeId, year, type])
  @@index([tenantId])
  @@index([employeeId])
  @@map("time_wallets")
}

model TimeDeduction {
  id             String         @id @default(cuid())
  tenantId       String         @default("")
  employeeId     String
  employee       Employee       @relation(fields: [employeeId], references: [id])
  leaveRequestId String?
  walletType     TimeWalletType
  hours          Float
  description    String
  createdAt      DateTime       @default(now())

  @@index([tenantId])
  @@index([employeeId])
  @@index([leaveRequestId])
  @@map("time_deductions")
}

model CompTimeAccrual {
  id                String   @id @default(cuid())
  tenantId          String   @default("")
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id])
  overtimeRequestId String?
  overtimeHours     Float
  multiplier        Float
  earnedHours       Float
  createdAt         DateTime @default(now())

  @@index([tenantId])
  @@index([employeeId])
  @@index([overtimeRequestId])
  @@map("comp_time_accruals")
}

model CompensationPolicy {
  id                String  @id @default(cuid())
  tenantId          String  @default("")
  compensationType  String  @default("COMP_TIME")
  weekdayMultiplier Float   @default(1.5)
  nightMultiplier   Float   @default(2.0)
  holidayMultiplier Float   @default(2.0)
  dailyWorkHours    Float   @default(8)
  halfDayHours      Float   @default(4)
  minUseUnit        Float   @default(1)
  deductionOrder    String  @default("COMP_TIME,ANNUAL")
  autoSplitDeduct   Boolean @default(true)
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@map("compensation_policies")
}

// ============================================================
// 복지 시스템 - 회사별 맞춤 복지 혜택 관리
// ============================================================

model WelfareCategory {
  id          String        @id @default(cuid())
  tenantId    String        @default("")
  name        String
  description String?
  icon        String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  items       WelfareItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("welfare_categories")
}

model WelfareItem {
  id          String            @id @default(cuid())
  tenantId    String            @default("")
  categoryId  String
  category    WelfareCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  benefitType String            @default("MONEY")
  amount      Float?
  unit        String            @default("원")
  maxPerYear  Int?
  formFields  String?
  requireApproval Boolean       @default(true)
  isActive    Boolean           @default(true)
  requests    WelfareRequest[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@index([tenantId])
  @@map("welfare_items")
}

model WelfareRequest {
  id          String      @id @default(cuid())
  tenantId    String      @default("")
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  itemId      String
  item        WelfareItem @relation(fields: [itemId], references: [id])
  status      String      @default("PENDING")
  amount      Float?
  note        String?
  formValues  String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@index([itemId])
  @@map("welfare_requests")
}

model Attendance {
  id            String    @id @default(cuid())
  tenantId      String    @default("")
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date          DateTime
  clockIn       DateTime?
  clockOut      DateTime?
  workHours     Float?
  overtimeHours Float?    @default(0)
  status        String    @default("NORMAL")
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([employeeId])
  @@index([date])
  @@map("attendances")
}
