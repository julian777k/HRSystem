# ===========================================
# MSA HR 시스템 환경 변수
# ===========================================
# 이 파일을 .env로 복사한 후 값을 수정하세요
# cp .env.example .env

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/msa_hr"

# ---- Authentication ----
JWT_SECRET="your-secret-key-change-this-in-production"
SESSION_EXPIRY_HOURS=24

# ---- Company (설정 마법사 또는 환경변수로 설정) ----
COMPANY_NAME=""
COMPANY_BIZ_NUMBER=""

# ---- Email (선택 - 알림 기능 사용 시) ----
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"

# ---- Admin (초기 관리자 - 설정 마법사에서 사용) ----
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
